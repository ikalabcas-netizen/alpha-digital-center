# ─────────────────────────────────────────────────
# PostgreSQL (self-hosted)
# ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-super-secret-password
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:your-super-secret-password@localhost:5432/postgres

# ─────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# GoTrue / Auth
API_EXTERNAL_URL=http://localhost:9999
ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false
FACEBOOK_AUTH_ENABLED=false

# ─────────────────────────────────────────────────
# AI API Keys
# ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
GOOGLE_AI_API_KEY=AIzaxxxxx
DEEPSEEK_API_KEY=sk-xxxxx

# ─────────────────────────────────────────────────
# Facebook
# ─────────────────────────────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token

# ─────────────────────────────────────────────────
# Analytics & Tracking
# ─────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=your-fb-pixel-id

# ─────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
