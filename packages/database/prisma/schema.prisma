generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH (NextAuth + Google OAuth + SSO) ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  HR_MANAGER
  EMPLOYEE
  ACCOUNTANT
  SALES
  CUSTOMER
  PENDING
  REJECTED
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id              String           @id @default(uuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?        @map("email_verified")
  image           String?
  phone           String?
  role            UserRole         @default(PENDING)
  isActive        Boolean          @default(false) @map("is_active")
  accounts        Account[]
  sessions        Session[]
  loginLogs       LoginLog[]
  customerProfile CustomerProfile?
  employee        HrmEmployee?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("users")
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   @default("google")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("login_logs")
}

model CustomerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  labName         String?  @map("lab_name")
  taxCode         String?  @map("tax_code")
  city            String?
  district        String?
  address         String?  @db.Text
  dentistName    String?  @map("dentist_name")
  source          String?  // "manual" | "lead_conversion" | "self_register"
  convertedLeadId String?  @map("converted_lead_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("customer_profiles")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== SITE SETTINGS ====================

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  group     String   // "hero", "stats", "contact", "about", "general"
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ==================== PRODUCT CATALOG ====================

model ProductCategory {
  id          String    @id @default(uuid())
  nameVi      String    @map("name_vi")
  nameEn      String?   @map("name_en")
  slug        String    @unique
  descriptionVi String? @map("description_vi")
  descriptionEn String? @map("description_en")
  displayOrder  Int     @default(0) @map("display_order")
  imageUrl    String?   @map("image_url")
  isActive    Boolean   @default(true) @map("is_active")
  parentId    String?   @map("parent_category_id")
  parent      ProductCategory? @relation("CategoryParent", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryParent")
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("product_categories")
}

model Product {
  id            String    @id @default(uuid())
  categoryId    String    @map("category_id")
  category      ProductCategory @relation(fields: [categoryId], references: [id])
  sku           String?   @unique
  nameVi        String    @map("name_vi")
  nameEn        String?   @map("name_en")
  slug          String    @unique
  descriptionVi String?   @map("description_vi") @db.Text
  descriptionEn String?   @map("description_en") @db.Text
  material      String?
  origin        String?
  warrantyYears Int?      @map("warranty_years")
  displayOrder  Int       @default(0) @map("display_order")
  isActive      Boolean   @default(true) @map("is_active")
  isFeatured    Boolean   @default(false) @map("is_featured")
  seoTitle      String?   @map("seo_title")
  seoDescription String?  @map("seo_description")
  variants      ProductVariant[]
  images        ProductImage[]
  warranties    WarrantyRecord[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("products")
}

model ProductVariant {
  id          String    @id @default(uuid())
  productId   String    @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  nameVi      String    @map("variant_name_vi")
  nameEn      String?   @map("variant_name_en")
  unit        String    // "Cái", "Hàm", "Khung"
  priceVnd    BigInt    @map("price_vnd")
  priceNote   String?   @map("price_note")
  isActive    Boolean   @default(true) @map("is_active")
  warranties  WarrantyRecord[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("product_variants")
}

model ProductImage {
  id          String    @id @default(uuid())
  productId   String    @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl    String    @map("image_url")
  altTextVi   String?   @map("alt_text_vi")
  displayOrder Int      @default(0) @map("display_order")
  isPrimary   Boolean   @default(false) @map("is_primary")

  @@map("product_images")
}

// ==================== WARRANTY ====================

model WarrantyRecord {
  id              String    @id @default(uuid())
  warrantyCode    String    @unique @map("warranty_code")
  patientName     String?   @map("patient_name")
  dentistName     String?   @map("dentist_name")
  labName         String?   @map("lab_name")
  productId       String?   @map("product_id")
  product         Product?  @relation(fields: [productId], references: [id])
  variantId       String?   @map("product_variant_id")
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  teethPositions  String?   @map("teeth_positions")
  shade           String?
  productionDate  DateTime  @map("production_date")
  warrantyExpiry  DateTime  @map("warranty_expiry")
  status          String    @default("active") // active, claimed, expired
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("warranty_records")
}

// ==================== BLOG / CONTENT ====================

model BlogPost {
  id              String    @id @default(uuid())
  titleVi         String    @map("title_vi")
  titleEn         String?   @map("title_en")
  slug            String    @unique
  excerptVi       String?   @map("excerpt_vi") @db.Text
  contentVi       String    @map("content_vi") @db.Text
  contentEn       String?   @map("content_en") @db.Text
  featuredImageUrl String?  @map("featured_image_url")
  category        String?   // "tin-tuc", "kien-thuc", "cong-nghe", "tuyen-dung"
  tags            String[]
  status          String    @default("draft") // draft, scheduled, published
  publishedAt     DateTime? @map("published_at")
  scheduledAt     DateTime? @map("scheduled_at")
  seoTitle        String?   @map("seo_title")
  seoDescription  String?   @map("seo_description")
  viewCount       Int       @default(0) @map("view_count")
  aiGenerated     Boolean   @default(false) @map("ai_generated")
  aiProvider      String?   @map("ai_provider") // "claude", "gemini", "deepseek"
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("blog_posts")
}

// ==================== LEADS ====================

model Lead {
  id              String    @id @default(uuid())
  source          String    // "website", "facebook", "phone", "zalo"
  labName         String?   @map("lab_name")
  contactName     String    @map("contact_name")
  phone           String?
  email           String?
  city            String?
  message         String?   @db.Text
  productInterest String?   @map("product_interest")
  status          String    @default("new") // new, contacted, qualified, converted
  assignedTo      String?   @map("assigned_to")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("leads")
}

// ==================== RECRUITMENT ====================

model JobPosting {
  id              String    @id @default(uuid())
  titleVi         String    @map("title_vi")
  slug            String    @unique
  department      String?
  location        String    @default("TP.HCM")
  employmentType  String?   @map("employment_type") // "full-time", "part-time"
  descriptionVi   String    @map("description_vi") @db.Text
  requirementsVi  String?   @map("requirements_vi") @db.Text
  benefitsVi      String?   @map("benefits_vi") @db.Text
  salaryRange     String?   @map("salary_range")
  isActive        Boolean   @default(true) @map("is_active")
  publishedAt     DateTime? @map("published_at")
  applications    JobApplication[]
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("job_postings")
}

model JobApplication {
  id            String    @id @default(uuid())
  jobId         String?   @map("job_id")
  job           JobPosting? @relation(fields: [jobId], references: [id])
  applicantName String    @map("applicant_name")
  phone         String
  email         String?
  cvUrl         String?   @map("cv_url")
  coverLetter   String?   @map("cover_letter") @db.Text
  status        String    @default("received") // received, reviewing, interview, hired, rejected
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("job_applications")
}

// ==================== MARKETING CAMPAIGNS ====================

model Campaign {
  id              String    @id @default(uuid())
  name            String
  type            String    // "blog_post", "fb_page_post", "fb_ad", "fb_group_post"
  status          String    @default("draft") // draft, scheduled, active, completed, paused
  contentVi       String?   @map("content_vi") @db.Text
  imageUrls       String[]  @map("image_urls")
  targetAudience  String?   @map("target_audience") @db.Text
  budgetVnd       BigInt?   @map("budget_vnd")
  scheduledAt     DateTime? @map("scheduled_at")
  publishedAt     DateTime? @map("published_at")
  fbPostId        String?   @map("fb_post_id")
  fbAdId          String?   @map("fb_ad_id")
  metrics         Json?     // {impressions, clicks, leads, cost}
  calendarEntries ContentCalendar[]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("campaigns")
}

model ContentCalendar {
  id          String    @id @default(uuid())
  date        DateTime
  campaignId  String?   @map("campaign_id")
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  contentType String    @map("content_type") // "blog", "fb_page", "fb_group", "fb_ad"
  title       String?
  notes       String?   @db.Text
  status      String    @default("planned") // planned, content_ready, published
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("content_calendar")
}

// ==================== TESTIMONIALS ====================

model Testimonial {
  id            String    @id @default(uuid())
  labName       String    @map("lab_name")
  contactPerson String?   @map("contact_person")
  contentVi     String    @map("content_vi") @db.Text
  rating        Int?      // 1-5
  imageUrl      String?   @map("image_url")
  isFeatured    Boolean   @default(false) @map("is_featured")
  isApproved    Boolean   @default(false) @map("is_approved")
  displayOrder  Int       @default(0) @map("display_order")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("testimonials")
}

// ==================== AI CONTENT GENERATION ====================

model AiGeneration {
  id          String    @id @default(uuid())
  provider    String    // "claude", "gemini", "deepseek"
  model       String    // "claude-sonnet-4-6", "gemini-2.0-flash", "deepseek-chat"
  contentType String    @map("content_type") // "blog", "fb_post", "product_desc", "recruitment"
  prompt      String    @db.Text
  output      String    @db.Text
  inputTokens Int?      @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  costUsd     Float?    @map("cost_usd")
  status      String    @default("generated") // generated, approved, rejected, published
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("ai_generations")
}

model AiSetting {
  id          String    @id @default(uuid())
  provider    String    @unique // "claude", "gemini", "deepseek"
  apiKey      String    @map("api_key")
  model       String    @default("")
  isActive    Boolean   @default(true) @map("is_active")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("ai_settings")
}

// ==================== CMS CONTENT (editable qua admin) ====================

model CmsPageHero {
  id          String    @id @default(uuid())
  pageSlug    String    @unique @map("page_slug") // "home","about","products","news","warranty","careers","contact"
  eyebrow     String
  titleLead   String    @map("title_lead")
  titleAccent String?   @map("title_accent")
  titleTail   String?   @map("title_tail")
  subtitle    String?   @db.Text
  imageUrl    String?   @map("image_url")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("cms_page_hero")
}

model CmsTechCard {
  id           String    @id @default(uuid())
  tag          String
  meta         String
  title        String
  description  String    @db.Text
  imageUrl     String    @map("image_url")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  @@map("cms_tech_cards")
}

model CmsMaterial {
  id           String    @id @default(uuid())
  name         String
  country      String
  material     String
  sinceYear    String    @map("since_year")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")

  @@map("cms_materials")
}

model CmsCoreValue {
  id           String    @id @default(uuid())
  number       String
  title        String
  description  String    @db.Text
  displayOrder Int       @default(0) @map("display_order")

  @@map("cms_core_values")
}

model CmsTimelineEntry {
  id           String    @id @default(uuid())
  year         String
  title        String
  description  String    @db.Text
  displayOrder Int       @default(0) @map("display_order")

  @@map("cms_timeline_entries")
}

model CmsStoryBlock {
  id          String    @id @default(uuid())
  pageSlug    String    @unique @map("page_slug") // "about"
  imageUrl1   String?   @map("image_url_1")
  imageUrl2   String?   @map("image_url_2")
  paragraph1  String    @db.Text
  paragraph2  String    @db.Text
  foundedYear String    @map("founded_year")

  @@map("cms_story_blocks")
}

model CmsWarrantyPolicyGroup {
  id           String                   @id @default(uuid())
  categoryName String                   @map("category_name")
  displayOrder Int                      @default(0) @map("display_order")
  items        CmsWarrantyPolicyItem[]

  @@map("cms_warranty_policy_groups")
}

model CmsWarrantyPolicyItem {
  id           String                 @id @default(uuid())
  groupId      String                 @map("group_id")
  group        CmsWarrantyPolicyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  productName  String                 @map("product_name")
  warrantyText String                 @map("warranty_text")
  displayOrder Int                    @default(0) @map("display_order")

  @@map("cms_warranty_policy_items")
}

model CmsContactChannel {
  id           String   @id @default(uuid())
  label        String
  value        String
  subtitle     String
  iconKey      String   @map("icon_key") // "phone" | "mail" | "zalo" | "clock"
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("cms_contact_channels")
}

model CmsJobPerk {
  id           String   @id @default(uuid())
  title        String
  description  String   @db.Text
  iconKey      String?  @map("icon_key")
  displayOrder Int      @default(0) @map("display_order")

  @@map("cms_job_perks")
}

// ==================== HRM (noibo.alphacenter.vn) — Phase 1: Org structure ====================

model HrmDepartment {
  id          String          @id @default(uuid())
  code        String          @unique // "LAB", "SALES", "HR"
  name        String
  description String?         @db.Text
  parentId    String?         @map("parent_id")
  parent      HrmDepartment?  @relation("HrmDeptParent", fields: [parentId], references: [id])
  children    HrmDepartment[] @relation("HrmDeptParent")
  managerId   String?         @map("manager_id") // hrm_employees.id (no FK to avoid circular cascade)
  positions   HrmPosition[]
  employees   HrmEmployee[]
  isActive    Boolean         @default(true) @map("is_active")
  displayOrder Int            @default(0) @map("display_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("hrm_departments")
}

model HrmPosition {
  id           String        @id @default(uuid())
  departmentId String        @map("department_id")
  department   HrmDepartment @relation(fields: [departmentId], references: [id])
  code         String        @unique // "KTV_SR", "QC_LEAD"
  title        String
  description  String?       @db.Text
  level        Int           @default(1) // 1..5 career ladder
  isActive     Boolean       @default(true) @map("is_active")
  employees    HrmEmployee[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([departmentId])
  @@map("hrm_positions")
}

model HrmEmployee {
  id               String        @id @default(uuid())
  employeeCode     String        @unique @map("employee_code") // "ADC-0001"
  userId           String?       @unique @map("user_id")
  user             User?         @relation(fields: [userId], references: [id])
  fullName         String        @map("full_name")
  dob              DateTime?     @db.Date
  gender           String? // "male" | "female" | "other"
  phone            String?
  personalEmail    String?       @map("personal_email")
  workEmail        String        @unique @map("work_email")
  nationalId       String?       @map("national_id") // CCCD
  address          String?       @db.Text
  avatarUrl        String?       @map("avatar_url")
  departmentId     String        @map("department_id")
  department       HrmDepartment @relation(fields: [departmentId], references: [id])
  positionId       String        @map("position_id")
  position         HrmPosition   @relation(fields: [positionId], references: [id])
  managerId        String?       @map("manager_id")
  manager          HrmEmployee?  @relation("HrmEmpManager", fields: [managerId], references: [id])
  reports          HrmEmployee[] @relation("HrmEmpManager")
  hireDate         DateTime      @map("hire_date") @db.Date
  probationEndDate DateTime?     @map("probation_end_date") @db.Date
  terminationDate  DateTime?     @map("termination_date") @db.Date
  employmentStatus String        @default("probation") @map("employment_status")
  // "probation" | "active" | "on_leave" | "terminated"
  employmentType   String        @default("full_time") @map("employment_type")
  // "full_time" | "part_time" | "contractor" | "intern"
  hrRole           String        @default("employee") @map("hr_role")
  // "hr_admin" | "hr_manager" | "manager" | "employee"
  note             String?       @db.Text

  shiftAssignments HrmShiftAssignment[]
  attendances      HrmAttendance[]
  leaveRequests    HrmLeaveRequest[]    @relation("LeaveOwner")
  leavesApproved   HrmLeaveRequest[]    @relation("LeaveApprover")

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([departmentId])
  @@index([positionId])
  @@index([managerId])
  @@map("hrm_employees")
}

// ==================== HRM Phase 2: Attendance + Leave ====================

model HrmShiftTemplate {
  id           String               @id @default(uuid())
  code         String               @unique // "SHIFT_A", "SHIFT_NIGHT"
  name         String
  startTime    String               @map("start_time") // "HH:mm" — "08:00"
  endTime      String               @map("end_time") // "HH:mm" — "17:00"
  breakMinutes Int                  @default(60) @map("break_minutes")
  shiftType    String               @default("day") // "day" | "night" | "flexible"
  // Late/Early threshold in minutes
  lateAfterMin Int                  @default(15) @map("late_after_min")
  isActive     Boolean              @default(true) @map("is_active")
  assignments  HrmShiftAssignment[]
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("hrm_shift_templates")
}

model HrmShiftAssignment {
  id         String           @id @default(uuid())
  employeeId String           @map("employee_id")
  employee   HrmEmployee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  templateId String           @map("template_id")
  template   HrmShiftTemplate @relation(fields: [templateId], references: [id])
  workDate   DateTime         @map("work_date") @db.Date
  note       String?
  createdAt  DateTime         @default(now()) @map("created_at")

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@map("hrm_shift_assignments")
}

model HrmAttendance {
  id          String      @id @default(uuid())
  employeeId  String      @map("employee_id")
  employee    HrmEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workDate    DateTime    @map("work_date") @db.Date
  clockInAt   DateTime?   @map("clock_in_at")
  clockOutAt  DateTime?   @map("clock_out_at")
  clockInLat  Float?      @map("clock_in_lat")
  clockInLng  Float?      @map("clock_in_lng")
  clockInIp   String?     @map("clock_in_ip")
  clockOutLat Float?      @map("clock_out_lat")
  clockOutLng Float?      @map("clock_out_lng")
  clockOutIp  String?     @map("clock_out_ip")
  status      String      @default("present") // "present"|"late"|"absent"|"half_day"|"remote"
  workMinutes Int?        @map("work_minutes")
  note        String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@map("hrm_attendances")
}

model HrmLeaveRequest {
  id            String      @id @default(uuid())
  employeeId    String      @map("employee_id")
  employee      HrmEmployee @relation("LeaveOwner", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     String      @map("leave_type")
  // "annual"|"sick"|"unpaid"|"maternity"|"wedding"|"bereavement"|"other"
  startDate     DateTime    @map("start_date") @db.Date
  endDate       DateTime    @map("end_date") @db.Date
  totalDays     Float       @map("total_days") // hỗ trợ nửa ngày 0.5
  reason        String?     @db.Text
  attachmentUrl String?     @map("attachment_url")
  status        String      @default("pending") // "pending"|"approved"|"rejected"|"cancelled"
  approverId    String?     @map("approver_id")
  approver      HrmEmployee? @relation("LeaveApprover", fields: [approverId], references: [id])
  approvedAt    DateTime?   @map("approved_at")
  rejectReason  String?     @map("reject_reason") @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([employeeId, status])
